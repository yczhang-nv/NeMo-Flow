{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "outDir": ".test-dist"
  },
  "exclude": [
    ".test-dist/**",
    "dist/**"
  ],
  "include": [
    "index.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "test/**/*.ts"
  ]
}
